# ── BridgeBack — FREE Setup ───────────────────────────────────────────────────
# Copy this to .env and fill in ONE of the free options below.

# ════════════════════════════════════════════════════════════
# OPTION A — Groq (RECOMMENDED FREE)
# 1. Go to: https://console.groq.com
# 2. Sign up (free, no credit card)
# 3. Click "API Keys" → Create key → paste below
# ════════════════════════════════════════════════════════════
GROQ_API_KEY=your_groq_key_here
DEFAULT_LLM=groq

# ════════════════════════════════════════════════════════════
# OPTION B — Google Gemini (FREE)
# 1. Go to: https://aistudio.google.com
# 2. Sign in with Google → "Get API key" → paste below
# ════════════════════════════════════════════════════════════
# GEMINI_API_KEY=your_gemini_key_here
# DEFAULT_LLM=gemini

# ════════════════════════════════════════════════════════════
# OPTION C — Ollama (LOCAL, 100% FREE, no internet needed)
# 1. Install from: https://ollama.ai
# 2. Run: ollama pull llama3.1
# 3. Run: ollama serve
# ════════════════════════════════════════════════════════════
# DEFAULT_LLM=ollama
# OLLAMA_MODEL=llama3.1
# OLLAMA_URL=http://localhost:11434

# ── Optional ──────────────────────────────────────────────────────────────────
MEETUP_API_KEY=
USER_LOCATION=Jamshedpur
DATABASE_URL=sqlite:///bridgeback.db

# ── Twilio WhatsApp (for accountability reminders) ───────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ── Telegram Bot (for 100% Free Nudges) ───────────────────────────
# TELEGRAM_BOT_TOKEN=

# ── Push notifications (FCM server key fallback path) ────────────────────────
# FCM_SERVER_KEY=

# ── API security and CORS ─────────────────────────────────────────────────────
# API_AUTH_TOKEN=change_this_token
# CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# ── Production persistence example (Postgres) ─────────────────────────────────
# DATABASE_URL=postgresql+psycopg://bridgeback:bridgeback@localhost:5432/bridgeback
