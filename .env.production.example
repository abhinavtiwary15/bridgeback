# BridgeBack production environment template
# Copy to your deployment secret manager / runtime env (do not commit real values).

# --- API security ---
API_AUTH_TOKEN=replace_with_long_random_token
CORS_ORIGINS=https://your-web-app.com,https://your-admin-app.com

# --- Database (Postgres recommended) ---
DATABASE_URL=postgresql+psycopg://bridgeback:replace_password@db-host:5432/bridgeback

# --- LLM provider (choose at least one) ---
DEFAULT_LLM=groq
GROQ_API_KEY=replace_groq_key
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Community/events ---
MEETUP_API_KEY=
USER_LOCATION=

# --- Accountability reminders ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+10000000000
REMINDER_COOLDOWN_HOURS=24

# --- Push notifications ---
FCM_SERVER_KEY=
